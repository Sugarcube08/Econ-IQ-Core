# Econiq Core Environment Settings
APP_NAME=Econiq Core Platform
APP_ENV=development
DEBUG=True
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8000
WORKERS=1

# PostgreSQL
POSTGRES_URL=postgresql+asyncpg://user:password:port/db
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_TIMEOUT=30
ENABLE_PERSISTENT_STATE=True

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_DB=0
REDIS_TIMEOUT=5

# Auth & JWT (EdDSA Keys)
JWT_ALGORITHM=EdDSA
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
JWT_ISSUER=econiq.intelligence
JWT_AUDIENCE=econiq.api

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=no-reply@econiq.core
SMTP_USE_TLS=False
EMAIL_SERVICE=False

# Worker Tuning
ENABLE_BACKGROUND_WORKERS=True
STARTUP_MODE=full # api-only, full, recovery
INTELLIGENCE_POLL_INTERVAL=5
SYNC_POLL_INTERVAL=5
POLARS_MAX_THREADS=1
SYNC_BATCH_SIZE=500
INTELLIGENCE_CHUNK_SIZE=10
RECOMPUTE_BATCH_SIZE=10

# Cryptographic Peppers
OTP_PEPPER=your_strong_pepper_1
API_KEY_PEPPER=your_strong_pepper_2
REFRESH_TOKEN_PEPPER=your_strong_pepper_3

# Observability
ENABLE_METRICS=True
ENABLE_TRACING=True
ENABLE_AUDIT_LOGGING=True
